# Copy this to .env.local and fill in your values
# At least ONE of these is required to receive leads

# ── Option A: Formspree (easiest, free) ──
# 1. Go to https://formspree.io → New Form → get your form ID (e.g. "xyzabcde")
# 2. Paste it below
FORMSPREE_ID=your_formspree_id_here

# ── Option B: Webhook (Make.com, Zapier, n8n, etc.) ──
# Create a webhook trigger in Make/Zapier → paste the URL below
# Make.com → free tier → connects to Google Sheets, Gmail, Slack, etc.
WEBHOOK_URL=https://hook.make.com/your-webhook-url-here
